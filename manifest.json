{
  "manifest_version": 3,
  "name": "AI Comment Generator",
  "version": "1.0.0",
  "description": "Generate AI-powered, human-like replies to LinkedIn and Twitter/X posts using Gemini or local Ollama.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["src/content-linkedin.js"],
      "css": ["src/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["src/content-twitter.js"],
      "css": ["src/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://reddit.com/*"
      ],
      "js": ["src/content-reddit.js"],
      "css": ["src/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
